# 研究室の許可IPをカンマ区切りで列挙
# 形式の例:
#   - 127.0.0.1, ::1         : ローカル開発用（自分のPCから自分のサーバー）
#   - ::ffff:192.168.x.x     : 同じLAN内の端末から叩いたときのLAN IP
#   - <PUBLIC_IP>            : 研究室Wi-Fi の公開IP（クラウドデプロイ時に効く）
# ★ 研究室の実IPはここに書かない。各自の .env に書く（Notion or LINE で共有）
LAB_ALLOWED_IPS=127.0.0.1,::1

# サーバーポート
PORT=3001

# 認証用シークレット（認証トークンの署名に使う。openssl rand -hex 32 等で生成）
JWT_SECRET=dev-secret-change-me
