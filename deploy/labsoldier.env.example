# 本番用 環境変数のテンプレート。
# VM 上で /opt/labsoldier-data/labsoldier.env としてコピーし、実値を入れる（git には上げない）。
# ★ 保存先 /opt/labsoldier-data は rsync 対象(/opt/labsoldier)の外。再デプロイの --delete で消えないようにするため。

NODE_ENV=production
PORT=3001

# SQLite の保存先（永続ディレクトリ・rsync対象外）
DB_PATH=/opt/labsoldier-data/labsoldier.db

# token 署名用シークレット。必ずランダムな長い文字列に。
# 生成例: openssl rand -hex 32
JWT_SECRET=__CHANGE_ME__

# 研究室 Wi-Fi の公開IPをカンマ区切りで。クラウド配置だとクライアントの送信元IPが届く。
# 例: LAB_ALLOWED_IPS=203.0.113.10,2400:xxxx:xxxx::1
LAB_ALLOWED_IPS=

# 同一オリジン配信なら不要。フロントを別ドメインに置く場合だけ設定。
# FRONTEND_ORIGIN=https://example.com
